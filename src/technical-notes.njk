---
layout: layouts/base.njk
title: Technical Notes
description: Documentation-style notes on iOS, Swift, systems, and backend engineering.
bodyClass: notes-index
---
<section class="wrap page-intro">
  <p class="eyebrow">Technical Notes</p>
  <h1 class="page__title">Notes from the workbench.</h1>
  <p class="page__lede">
    Technical learning notes, write-ups of challenges I ran into while building, and
    references I keep for myself while figuring things out.
  </p>
</section>

<section class="wrap">
  <ol class="doc-list">
    {% for note in collections.notes %}
      {% set tr = note.data.ref | findTranslation(collections.noteTranslation) %}
      <li class="doc-list__item">
        <a class="doc-list__link" href="{{ note.url }}">
          <div class="doc-list__main">
            <h2 class="doc-list__title">{{ note | preferredNoteTitle(collections.noteTranslation) }}{% if tr %}<span class="bilingual-badge" title="Available in English and 中文">EN · 中文</span>{% endif %}</h2>
            {% if note.data.tags %}
              <ul class="taglist taglist--sm">
                {% for t in note.data.tags %}<li>{{ t }}</li>{% endfor %}
              </ul>
            {% endif %}
          </div>
          <div class="doc-list__meta">
            <time datetime="{{ note.date | isoDate }}">{{ note.date | readableDate }}</time>
            <span class="doc-list__rt">{{ note.templateContent | readingTime }}</span>
          </div>
        </a>
      </li>
    {% endfor %}
  </ol>
</section>
