<a class="skip-link" href="#main">Skip to content</a>
<header class="site-header">
  <div class="wrap site-header__inner">
    <a class="brand" href="/">
      <span class="brand__mark">Z</span>
      <span class="brand__name">Ziyan&nbsp;Song</span>
    </a>
    <nav class="site-nav" aria-label="Primary">
      <button class="nav-toggle" aria-expanded="false" aria-controls="nav-list" aria-label="Toggle menu">
        <span></span><span></span>
      </button>
      <ul class="nav-list" id="nav-list">
        {% for item in site.nav %}
          {% set isHome = item.url == "/" and page.url == "/" %}
          {% set isSection = item.url != "/" and (page.url | string).startsWith(item.url) %}
          <li>
            <a href="{{ item.url }}" {% if isHome or isSection %}aria-current="page"{% endif %}>{{ item.label }}</a>
          </li>
        {% endfor %}
        <li class="nav-list__theme">
          <button class="theme-toggle" aria-label="Toggle dark mode" title="Toggle theme">
            <span class="theme-toggle__icon" aria-hidden="true"></span>
          </button>
        </li>
      </ul>
    </nav>
  </div>
</header>
