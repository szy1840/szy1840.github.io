---
layout: layouts/base.njk
bodyClass: essay-page
---
<article class="essay wrap--narrow">
  <header class="essay__head">
    <p class="eyebrow"><a href="/notes-essays/">Notes &amp; Essays</a></p>
    <h1 class="essay__title">{{ title }}</h1>
    <div class="essay__meta">
      <time datetime="{{ page.date | isoDate }}">{{ page.date | readableDate(lang) }}</time>
      {% if subtitle %}<span class="dot">·</span><span>{{ subtitle }}</span>{% endif %}
    </div>
  </header>
  <div class="prose prose--essay {% if lang == 'zh' %}prose--zh{% endif %}">
    {{ content | safe }}
  </div>
  <footer class="essay__foot">
    <a class="back-link" href="/notes-essays/">← Back to writing</a>
  </footer>
</article>
