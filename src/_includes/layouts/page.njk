---
layout: layouts/base.njk
---
<article class="page wrap">
  {% if eyebrow %}<p class="eyebrow">{{ eyebrow }}</p>{% endif %}
  {% if title %}<h1 class="page__title">{{ title }}</h1>{% endif %}
  {% if lede %}<p class="page__lede">{{ lede }}</p>{% endif %}
  <div class="prose">
    {{ content | safe }}
  </div>
</article>
